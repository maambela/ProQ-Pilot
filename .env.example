# ProQ Pilot local development configuration.
# Do not commit real production secrets. Cloud Run should receive these from Google Secret Manager.

NODE_ENV=development
PORT=3000
PRODUCT_IMAGE_MAX_BYTES=3145728
PUBLIC_BASE_URL=http://localhost:3000

# MySQL local TCP. Cloud Run uses INSTANCE_CONNECTION_NAME with a Cloud SQL Unix socket.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=replace-with-local-password
DB_NAME=proq_pilot
DB_CONNECTION_LIMIT=10

# Cloud SQL, only needed when testing Cloud SQL socket locally with the proxy.
INSTANCE_CONNECTION_NAME=proq-pilot:us-central1:proq-pilot-db

# Auth
ACCESS_TOKEN_SECRET=replace-with-long-random-local-secret

# Microsoft Graph email
AZURE_TENANT_ID=replace-with-tenant-id
AZURE_CLIENT_ID=replace-with-client-id
AZURE_CLIENT_SECRET=replace-with-client-secret
EMAIL_NOREPLY_FROM=noreply@stackopsit.co.za
EMAIL_SUPPORT_FROM=support@stackopsit.co.za
EMAIL_SALES_FROM=sales@stackopsit.co.za

# PayFast
PAYFAST_MERCHANT_ID=replace-with-merchant-id
PAYFAST_MERCHANT_KEY=replace-with-merchant-key
PAYFAST_PASSPHRASE=replace-with-passphrase
PAYFAST_MODE=sandbox
PAYFAST_LIVE_URL=https://www.payfast.co.za/eng/process
PAYFAST_SANDBOX_URL=https://sandbox.payfast.co.za/eng/process
PAYFAST_RETURN_URL=http://localhost:3000/order-success.html
PAYFAST_CANCEL_URL=http://localhost:3000/cart.html
PAYFAST_NOTIFY_URL=http://localhost:3000/webhook/payfast

# Yoco
YOCO_SECRET_KEY=replace-with-yoco-secret-key
YOCO_WEBHOOK_SECRET=replace-with-yoco-webhook-secret-after-registration

# Axiz product API
AXIZ_CLIENT_ID=replace-with-axiz-client-id
AXIZ_CLIENT_SECRET=replace-with-axiz-client-secret
AXIZ_SCOPE=replace-with-axiz-scope
AXIZ_TOKEN_URL=replace-with-axiz-token-url
AXIZ_BASE_URL=replace-with-axiz-base-url
AXIZ_ACCOUNT_NUMBER=replace-with-axiz-account-number

# Supplier APIs
CORE_API_URL=replace-with-core-api-url
TARSON_API_URL=replace-with-tarson-api-url
TARSON_API_TOKEN=replace-with-tarson-api-token

# Duo API
DUO_IKEY=replace-with-duo-integration-key
DUO_SKEY=replace-with-duo-secret-key
DUO_HOST=replace-with-duo-api-hostname

# Westcon Microsoft License API
WESTCON_OAUTH_URL=replace-with-westcon-oauth-url
WESTCON_CLIENT_ID=replace-with-westcon-client-id
WESTCON_CLIENT_SECRET=replace-with-westcon-client-secret
WESTCON_RESOURCE_ID=replace-with-westcon-resource-id
WESTCON_SUBSCRIPTION_KEY=replace-with-westcon-subscription-key
WESTCON_API_BASE_URL=replace-with-westcon-api-base-url
WESTCON_MICROSOFT_LICENSES_PATH=/MsftLicensesReport/
WESTCON_REPORT_MAX=100

# Stitch Express Pay by Bank
# Production values should be stored in Google Secret Manager and injected by Cloud Run.
STITCH_CLIENT_ID=replace-with-stitch-express-client-id
STITCH_CLIENT_SECRET=replace-with-stitch-express-client-secret
STITCH_REDIRECT_URI=http://localhost:3000/api/v1/stitch-payment/verify
STITCH_WEBHOOK_SECRET=replace-with-stitch-express-webhook-secret-after-registration

# Production callback reference:
# STITCH_REDIRECT_URI=https://proqpilot.com/api/v1/stitch-payment/verify

